{
  "name": "aws-cleaner",
  "version": "1.0.0",
  "description": "AWS Resource Cleaner",
  "license": "ISC",
  "author": {
    "name": "Trevor Robinson"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./src/*": "./dist/*.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "lint": "eslint --max-warnings 0",
    "prepare": "husky",
    "prettier": "prettier --write .",
    "start": "tsx src/index.ts | pino-pretty",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-application-auto-scaling": "^3.1070.0",
    "@aws-sdk/client-cloudfront": "^3.1070.0",
    "@aws-sdk/client-cloudwatch": "^3.1070.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1070.0",
    "@aws-sdk/client-dynamodb": "^3.1070.0",
    "@aws-sdk/client-ec2": "^3.1070.0",
    "@aws-sdk/client-ecr": "^3.1070.0",
    "@aws-sdk/client-ecs": "^3.1070.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.1070.0",
    "@aws-sdk/client-elasticache": "^3.1070.0",
    "@aws-sdk/client-eventbridge": "^3.1070.0",
    "@aws-sdk/client-firehose": "^3.1070.0",
    "@aws-sdk/client-iam": "^3.1070.0",
    "@aws-sdk/client-kafka": "^3.1070.0",
    "@aws-sdk/client-kms": "^3.1070.0",
    "@aws-sdk/client-lambda": "^3.1070.0",
    "@aws-sdk/client-location": "^3.1070.0",
    "@aws-sdk/client-rds": "^3.1070.0",
    "@aws-sdk/client-resource-groups-tagging-api": "^3.1070.0",
    "@aws-sdk/client-route-53": "^3.1070.0",
    "@aws-sdk/client-s3": "^3.1070.0",
    "@aws-sdk/client-secrets-manager": "^3.1070.0",
    "@aws-sdk/client-servicediscovery": "^3.1070.0",
    "@aws-sdk/client-sns": "^3.1070.0",
    "@aws-sdk/client-ssm": "^3.1070.0",
    "@aws-sdk/client-sts": "^3.1070.0",
    "@octokit/graphql": "^9.0.3",
    "catch-unknown": "^2.0.0",
    "got": "^15.0.5",
    "js-yaml": "^4.2.0",
    "parse-duration": "^2.1.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.13.2",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --max-warnings 0",
      "prettier --write"
    ],
    "*.md": "prettier --write"
  },
  "prettier": {
    "printWidth": 120
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
